# Transit Display Backend — Environment
# Copy to .env and adjust.

# Required: secret token shared with the ESP32 (set in SD card config)
BRIDGE_TOKEN=change-me

# Set to "1" to use synthetic demo data (no VBB API needed)
# DEMO_MODE=1

# Path to profiles.json (defaults to backend/config/profiles.json)
# PROFILES_PATH=/custom/path/profiles.json
