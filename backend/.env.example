# Backend auth — must match SD card config
BRIDGE_TOKEN=change-me

# HAFAS API AID token (default: BVG mobile app token — works out of the box)
# Override if using a different HAFAS endpoint
# BRIDGE_HAFAS_AID=dVg4TZbW8anjx9ztPwe2uk4LVRi9wO

# Set to 1 for synthetic data (no VBB API needed)
# DEMO_MODE=0

# Path to profiles.json (default: backend/config/profiles.json)
# PROFILES_PATH=
